# Database Configuration
MONGOOSE_CONNTECTION_STRING=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/?retryWrites=true&w=majority

# JWT Authentication Keys
AUTH_KEY=your_jwt_secret_key_for_users
ADMIN_KEY=your_jwt_secret_key_for_admins

# LINE Login API Configuration
LINE_CLIENT_ID=your_line_client_id
LINE_CLIENT_SECRET=your_line_client_secret

# Gmail SMTP Configuration
GMAIL_PASSWORD=your_gmail_app_password
# 預約通知主信寄送失敗時的備援收件信箱（選填，建議設成與主收件人不同的信箱）
BOOKING_BACKUP_EMAIL=your_backup_inbox@example.com
# API 錯誤通知收件信箱（選填，預設 dontz3210@gmail.com）。5xx 與被包成 400 的真正例外會寄信通知
ERROR_NOTIFY_EMAIL=dontz3210@gmail.com

# Google Drive API Configuration
DRIVE_PROJECT_ID=your_google_drive_project_id
DRIVE_PRIVATE_KEY_ID=your_google_drive_private_key_id
DRIVE_KEY=-----BEGIN PRIVATE KEY-----\nyour_google_drive_private_key\n-----END PRIVATE KEY-----
DRIVE_CLIENT_EMAIL=your_service_account@your_project.iam.gserviceaccount.com
DRIVE_CLIENT_ID=your_google_drive_client_id

# Cloudflare R2 Storage Configuration
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://your_r2_public_url